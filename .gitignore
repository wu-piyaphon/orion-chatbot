*.log
logs/

# OS
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
# Secrets — never commit real credentials
# ──────────────────────────────────────────────
# Keep appsettings.json as a template (with YOUR_* placeholders).
# Override with appsettings.Development.json locally — never commit it.
appsettings.Development.json
appsettings.Production.json
appsettings.*.local.json

# .NET user secrets (dotnet user-secrets)
**/secrets.json
